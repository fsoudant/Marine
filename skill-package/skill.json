{
  "manifest": {
    "publishingInformation": {
      "locales": {
        "fr-FR": {
          "name": "Météo Marine",
          "summary": "Obtenez la météo marine et les horaires de marées pour n'importe quel port français.",
          "description": "Météo Marine vous donne instantanément les conditions en mer et les horaires de marées...",
          "examplePhrases": [
            "Alexa, ouvre Météo Marine",
            "Alexa, demande à Météo Marine la météo à Biarritz",
            "Alexa, demande à Météo Marine les marées à La Rochelle"
          ],
          "keywords": [
            "météo marine",
            "marées",
            "mer",
            "vagues",
            "coefficient",
            "port",
            "navigation",
            "plaisance"
          ]
        }
      },
      "isAvailableWorldwide": false,
      "category": "WEATHER",
      "distributionCountries": [
        "FR"
      ]
    },
    "apis": {
      "custom": {
        "endpoint": {
          "uri": "arn:aws:lambda:eu-west-3:357621881595:function:meteo-marine-skill"
        },
        "interfaces": [],
        "regions": {
          "EU": {
            "endpoint": {
              "uri": "arn:aws:lambda:eu-west-3:357621881595:function:meteo-marine-skill"
            }
          }
        }
      }
    },
    "permissions": [
      {
        "name": "alexa::devices:all:address:full:read"
      }
    ],
    "privacyAndCompliance": {
      "allowsPurchases": false,
      "usesPersonalInfo": true,
      "isChildDirected": false,
      "isExportCompliant": true,
      "containsAds": false,
      "locales": {
        "fr-FR": {
         "privacyPolicyUrl": "https://fsoudant.github.io/Marine/privacy.html",
		 "termsOfUseUrl": "https://fsoudant.github.io/Marine/terms.html"
        }
      }
    }
  }
}